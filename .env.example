# ─────────────────────────────────────────────────────────────
# Sahayak environment configuration (TEMPLATE — safe to commit)
# Copy this file to `.env` and fill in your own values.
# NEVER put a real key in this file. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# Required: your Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# LLM model served over Groq's OpenAI-compatible endpoint.
# Default below is high-quality. For lower latency on weak hardware use:
#   GROQ_MODEL=llama-3.1-8b-instant   (documented faster fallback)
GROQ_MODEL=llama-3.3-70b-versatile

# Server port (frontend dev server proxies /api here)
PORT=8787

# Comma-separated allowed CORS origins for the API (frontend dev URL)
CORS_ORIGIN=http://localhost:5173
